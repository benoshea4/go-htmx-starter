DATABASE_URL=postgres://user:password@localhost:5432/app?sslmode=disable
PORT=8080
ENV=development

# Keys are auto-generated on first run in dev — do not set these manually.
# In production, generate once and set as server environment variables (not in .env).
# Rotating these keys logs out all users cluster-wide.
ED25519_PRIVATE_KEY=
ED25519_PUBLIC_KEY=

# Email — leave blank in dev to print emails to stdout instead of sending.
# In production, set to your Resend API key and update the from address in mailer.go.
RESEND_API_KEY=
APP_URL=http://localhost:8080

# Production backup credentials (Cloudflare R2)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ACCOUNT_ID=

# Hetzner API token (for snapshot automation)
# HCLOUD_TOKEN=
